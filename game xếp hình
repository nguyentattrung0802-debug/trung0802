<!DOCTYPE html>
<html>
<head>
  <title>Mini Game</title>

  <style>
    body {
      text-align: center;
      font-family: Arial;
      background-color: lightblue;
    }

    .box {
      display: inline-block;
      width: 100px;
      height: 100px;
      margin: 20px;
      background-color: white;
      border: 2px solid black;
      font-size: 30px;
      line-height: 100px;
      cursor: pointer;
    }
  </style>
</head>

<body>

  <h1>Chọn ô đúng 😎</h1>

  <div class="box" onclick="check(1)">?</div>
  <div class="box" onclick="check(2)">?</div>
  <div class="box" onclick="check(3)">?</div>

  <script>
    function check(number) {
      if (number === 2) {
        alert("🎉 Bạn thắng!");
      } else {
        alert("❌ Sai rồi!");
      }
    }
  </script>

</body>
</html>
